# JWT (obligatorio en producción; usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_unico
# JWT_EXPIRES_IN=7d

# API
PORT=3000
# Origen del front en Vite (opcional; por defecto CORS abierto en dev)
# CORS_ORIGIN=http://127.0.0.1:5173

# Ordenación IA de la wishlist (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
